# .env.example — Bunu kopyala, .env olarak kaydet, gerçek keyleri yaz
# ASLA .env dosyasını git'e commit etme!

# Alpaca Paper Trading (test icin)
ALPACA_API_KEY=BURAYA_PAPER_KEY_YAZ
ALPACA_SECRET_KEY=BURAYA_PAPER_SECRET_YAZ
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca Live Trading (hazir olunca usttekileri bunlarla degistir)
# ALPACA_API_KEY=BURAYA_LIVE_KEY_YAZ
# ALPACA_SECRET_KEY=BURAYA_LIVE_SECRET_YAZ
# ALPACA_BASE_URL=https://api.alpaca.markets

# Alpha Vantage - Haber/Sentiment filtresi
# Ucretsiz key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=BURAYA_ALPHAVANTAGE_KEY_YAZ
